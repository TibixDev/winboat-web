---
import { Icon } from "astro-icon/components";
import winboat_logo from "../assets/winboat_logo.svg";
---

<section id="hero">
    <div class="flex min-h-[85dvh] flex-col items-center justify-center">
        <img src={winboat_logo.src} alt="WinBoat Logo" class="mb-4 h-56 w-56" />
        <div class="p-8 text-center">
            <h1 class="mb-4 bg-gradient-to-r from-neutral-300 to-white bg-clip-text text-2xl leading-9 font-bold text-transparent 2xl:text-5xl 2xl:leading-15">
                Run Windows apps on <span class="text-white">🐧</span> Linux<br />with <span class="text-indigo-400">✨ seamless</span> integration
            </h1>
        </div>
        <div class="flex flex-col gap-6 md:flex-row">
            <a
                href="#features"
                class="flex flex-row items-center justify-center gap-2 rounded-md bg-indigo-200 px-6 py-3 text-neutral-700 shadow-md shadow-indigo-200/60 transition ease-in-out hover:scale-x-105 hover:shadow-lg hover:shadow-indigo-200/70 hover:saturate-200 md:justify-start">
                <Icon class="h-6 w-6" name="fluent:apps-list-detail-32-filled" />
                Explore Features
            </a>
            <a
                href="#download"
                class="relative flex flex-row items-center justify-center gap-2 rounded-md bg-indigo-500 px-6 py-3 shadow-md shadow-indigo-500/60 transition ease-in-out hover:scale-x-105 hover:shadow-lg hover:shadow-indigo-500/70 hover:saturate-200 md:justify-start">
                <div class="absolute -top-2 -right-2 rotate-[10deg] rounded-sm bg-green-500 px-1 font-semibold text-black uppercase">Beta</div>
                <Icon class="h-6 w-6" name="fluent:arrow-download-32-filled" />
                Download
            </a>
        </div>
    </div>
</section>
